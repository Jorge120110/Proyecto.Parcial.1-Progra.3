package Servicio;

import java.net.URI;
import java.net.http.HttpClient;
import java.net.http.HttpRequest;
import java.net.http.HttpResponse;
import java.time.Duration;

import com.fasterxml.jackson.databind.ObjectMapper;

import modelos.LoteDeTransacciones;

public class TransaccionAPI {

    private final ObjectMapper objectMapper;
    
    private final String API_URL = "https://7e0d9ogwzd.execute-api.us-east-1.amazonaws.com/default/guardarTransacciones"; 

    public TransaccionAPI() {
        this.objectMapper = new ObjectMapper();
    }

    public LoteDeTransacciones obtenerTransacciones() throws Exception {
        HttpClient client = HttpClient.newBuilder()
                .connectTimeout(Duration.ofSeconds(10))
                .build();

        HttpRequest request = HttpRequest.newBuilder()
                .uri(URI.create(API_URL))
                .header("Accept", "application/json") 
                .GET() 
                .build();

        System.out.println("Conectando a la API de origen...");
        HttpResponse<String> response = client.send(request, HttpResponse.BodyHandlers.ofString());

        if (response.statusCode() == 200) {
             return objectMapper.readValue(response.body(), LoteDeTransacciones.class);
        } else {
            throw new RuntimeException("Error en la petición GET: " + response.statusCode() + " - " + response.body());
        }
    }
}