package Servicio;

import com.fasterxml.jackson.databind.ObjectMapper;
import modelos.Transaccion;
import java.net.URI;
import java.net.http.HttpClient;
import java.net.http.HttpRequest;
import java.net.http.HttpResponse;
import java.time.Duration;

public class TransaccionPostAPI {
    private final ObjectMapper objectMapper = new ObjectMapper();
    private final String POST_URL = "https://7e0d9ogwzd.execute-api.us-east-1.amazonaws.com/default/guardarTransacciones";

    public boolean enviarAPost(Transaccion tx) throws Exception {
        HttpClient client = HttpClient.newBuilder().connectTimeout(Duration.ofSeconds(10)).build();
         
        String jsonBody = objectMapper.writeValueAsString(tx);

        HttpRequest request = HttpRequest.newBuilder()
                .uri(URI.create(POST_URL))
                .header("Content-Type", "application/json") 
                .POST(HttpRequest.BodyPublishers.ofString(jsonBody)) 
                .build();

        HttpResponse<String> response = client.send(request, HttpResponse.BodyHandlers.ofString());
        return response.statusCode() == 200;
    }
}